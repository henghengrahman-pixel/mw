<section class="hero section">
  <div class="container">
    <p class="eyebrow">Toko Parfum Original di Poipet</p>
    <h1>Mawar Parfum Poipet</h1>
    <p class="lead">Parfum pria, wanita, dan unisex dengan pilihan ready stock, top seller, dan harga terbaik di Poipet.</p>
    <div class="hero-actions">
      <a href="/products" class="btn">Lihat Produk</a>
      <a href="/checkout" class="btn btn-outline">Checkout</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head">
      <h2>Produk Top Seller</h2>
      <a href="/products">Lihat semua</a>
    </div>
    <div class="product-grid">
      <% (featured.length ? featured : products.slice(0, 8)).forEach(function(product) { %>
        <article class="product-card">
          <a href="/product/<%= product.slug %>" class="product-image-wrap">
            <img src="<%= product.image %>" alt="<%= product.alt %>" class="product-image" />
          </a>
          <div class="product-content">
            <p class="badge"><%= product.badge || (product.topSeller ? 'TOP SELLER' : product.category) %></p>
            <h3><a href="/product/<%= product.slug %>"><%= product.name %></a></h3>
            <p><%= product.desc %></p>
            <div class="product-row">
              <strong>Rp <%= Number(product.price).toLocaleString('id-ID') %></strong>
              <% if (product.soldOut) { %><span class="soldout">Sold Out</span><% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
