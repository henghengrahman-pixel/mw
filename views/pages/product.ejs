<section class="section">
  <div class="container">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/products">Produk</a>
      <span>/</span>
      <span><%= product.name %></span>
    </nav>

    <div class="product-detail">
      <div>
        <img src="<%= product.image %>" alt="<%= product.alt %>" class="product-detail-image" />
      </div>
      <div>
        <p class="badge"><%= product.badge || product.category %></p>
        <h1><%= product.name %></h1>
        <p class="lead"><%= product.desc %></p>
        <p class="price">Rp <%= Number(product.price).toLocaleString('id-ID') %></p>
        <ul class="notes-list">
          <% if (product.topNotes) { %><li><strong>Top Notes:</strong> <%= product.topNotes %></li><% } %>
          <% if (product.midNotes) { %><li><strong>Mid Notes:</strong> <%= product.midNotes %></li><% } %>
          <% if (product.baseNotes) { %><li><strong>Base Notes:</strong> <%= product.baseNotes %></li><% } %>
          <% if (product.aroma) { %><li><strong>Aroma:</strong> <%= product.aroma %></li><% } %>
        </ul>
        <% if (product.soldOut) { %>
          <p class="soldout">Produk sedang sold out</p>
        <% } else { %>
          <a href="/checkout?product=<%= encodeURIComponent(product.name) %>" class="btn">Checkout produk ini</a>
        <% } %>
      </div>
    </div>
  </div>
</section>

<section class="section section-soft">
  <div class="container">
    <div class="section-head">
      <h2>Produk terkait</h2>
      <a href="/products">Lihat semua</a>
    </div>
    <div class="product-grid">
      <% relatedProducts.forEach(function(item) { %>
        <article class="product-card">
          <a href="/product/<%= item.slug %>" class="product-image-wrap">
            <img src="<%= item.image %>" alt="<%= item.alt %>" class="product-image" />
          </a>
          <div class="product-content">
            <h3><a href="/product/<%= item.slug %>"><%= item.name %></a></h3>
            <p><%= item.desc %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
