<%- include('../partials/head') %>
<%- include('../partials/header', { activeNav }) %>

<main class="section">
  <div class="container">
    <div class="page-top">
      <div>
        <p class="eyebrow">Halaman artikel</p>
        <h1>Artikel Mawar Parfume</h1>
        <p class="lead">Konten untuk memperkuat keyword turunan seperti toko parfum Poipet, parfum original Poipet, dan rekomendasi parfum Poipet.</p>
      </div>
      <form class="search-form" method="get" action="/artikel">
        <input type="search" name="q" placeholder="Cari artikel..." value="<%= keyword %>">
        <button type="submit" class="btn btn-primary">Cari</button>
      </form>
    </div>

    <div class="article-grid">
      <% articles.forEach(function(article){ %>
        <article class="article-card">
          <img src="<%= article.coverImage %>" alt="<%= article.coverAlt %>" loading="lazy">
          <div class="article-card-body">
            <h2><a href="/artikel/<%= article.slug %>"><%= article.title %></a></h2>
            <p><%= article.excerpt %></p>
            <a class="text-link" href="/artikel/<%= article.slug %>">Baca selengkapnya</a>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
