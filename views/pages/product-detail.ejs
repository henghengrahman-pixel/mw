<%- include('../partials/head') %>
<%- include('../partials/header', { activeNav }) %>

<main class="section">
  <div class="container breadcrumb">
    <a href="/">Home</a>
    <span>/</span>
    <a href="/produk">Produk</a>
    <span>/</span>
    <span><%= product.name %></span>
  </div>

  <div class="container detail-grid">
    <div class="detail-media">
      <img src="<%= product.image %>" alt="<%= product.alt %>" loading="eager">
    </div>
    <article class="detail-content">
      <p class="eyebrow"><%= product.category %> • <%= product.volume %></p>
      <h1><%= product.name %></h1>
      <p class="price-large">Rp <%= Number(product.price).toLocaleString('id-ID') %></p>
      <p class="lead"><%= product.shortDescription %></p>
      <p><%= product.description %></p>

      <div class="notes-box">
        <div><strong>Top Notes:</strong> <%= product.topNotes || '-' %></div>
        <div><strong>Middle Notes:</strong> <%= product.middleNotes || '-' %></div>
        <div><strong>Base Notes:</strong> <%= product.baseNotes || '-' %></div>
      </div>

      <div class="tag-list">
        <% (product.keywords || []).forEach(function(keyword){ %>
          <span><%= keyword %></span>
        <% }) %>
      </div>
    </article>
  </div>

  <section class="container section section-related">
    <div class="section-head">
      <div>
        <p class="eyebrow">Internal linking</p>
        <h2>Produk terkait</h2>
      </div>
    </div>
    <div class="card-grid">
      <% relatedProducts.forEach(function(item){ %>
        <article class="product-card">
          <a href="/produk/<%= item.slug %>">
            <img src="<%= item.image %>" alt="<%= item.alt %>" loading="lazy">
          </a>
          <div class="product-card-body">
            <h3><a href="/produk/<%= item.slug %>"><%= item.name %></a></h3>
            <p><%= item.shortDescription %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
