<section class="section">
  <div class="container">
    <h1>Produk Mawar Parfum</h1>
    <form class="filter-bar" method="GET" action="/products">
      <input type="text" name="q" value="<%= query %>" placeholder="Cari parfum..." />
      <select name="category">
        <option value="">Semua kategori</option>
        <% ['MEN','WOMEN','UNISEX','MIX'].forEach(function(item) { %>
          <option value="<%= item %>" <%= category === item ? 'selected' : '' %>><%= item %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn">Filter</button>
    </form>

    <div class="product-grid">
      <% products.forEach(function(product) { %>
        <article class="product-card">
          <a href="/product/<%= product.slug %>" class="product-image-wrap">
            <img src="<%= product.image %>" alt="<%= product.alt %>" class="product-image" />
          </a>
          <div class="product-content">
            <p class="badge"><%= product.badge || product.category %></p>
            <h2><a href="/product/<%= product.slug %>"><%= product.name %></a></h2>
            <p><%= product.desc %></p>
            <div class="product-row">
              <strong>Rp <%= Number(product.price).toLocaleString('id-ID') %></strong>
              <% if (product.soldOut) { %><span class="soldout">Sold Out</span><% } %>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
