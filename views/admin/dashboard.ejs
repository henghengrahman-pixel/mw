<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dashboard Admin | Mawar Parfume</title>
  <meta name="robots" content="noindex,nofollow">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-admin">
  <main class="admin-shell">
    <%- include('partials/header', { current }) %>
    <section class="admin-cards">
      <article class="admin-card"><h2><%= stats.products %></h2><p>Total produk</p></article>
      <article class="admin-card"><h2><%= stats.articles %></h2><p>Total artikel</p></article>
      <article class="admin-card"><h2><%= stats.featured %></h2><p>Produk unggulan</p></article>
    </section>
    <section class="admin-panel">
      <h2>SEO utama saat ini</h2>
      <p><strong>Home title:</strong> <%= settings.homeMetaTitle %></p>
      <p><strong>Home description:</strong> <%= settings.homeMetaDescription %></p>
    </section>
  </main>
</body>
</html>
